# Runtime
ENV=development
HOST=0.0.0.0
PORT=8090

# Security
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
# Use one of the following strategies:
# 1) Direct URL
# SQLALCHEMY_DATABASE_URL=postgresql://user:password@localhost/creatorscan
# 2) Component fields (used when SQLALCHEMY_DATABASE_URL is empty)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_SERVER=localhost
POSTGRES_DB=creatorscan
SQLALCHEMY_DATABASE_URL=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_ORIGIN_REGEX=chrome-extension://.*
